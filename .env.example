# ── Funraise (primary embed + campaign link) ──────────────────────────────
# Campaign page URL — used as the "Donate ↗" link and fallback checkout URL.
NEXT_PUBLIC_FUNRAISE_CAMPAIGN_URL=https://beyondtyperun.funraise.org/fundraiser/drew-spooner

# Public API IDs (from browser HAR — no auth required).
# Page UUID identifies your individual fundraiser page.
NEXT_PUBLIC_FUNRAISE_PAGE_ID=1dd75249-443d-476f-ada3-8caae08f33be
# Optional override for the Funraise platform base URL (defaults to https://platform.funraise.io).
# NEXT_PUBLIC_FUNRAISE_PLATFORM_URL=https://platform.funraise.io

# Funraise Form V2 embed (button launcher). Both must be set to enable the in-page form.
# 1) The "Aware code" script URL from your Funraise account
# NEXT_PUBLIC_FUNRAISE_AWARE_SCRIPT_URL=https://your-org.funraise.org/?...
# 2) The form ID from the published button embed code
# NEXT_PUBLIC_FUNRAISE_FORM_ID=xxxxxx

# ── GoFundMe (optional fallback) ──────────────────────────────────────────
# Only needed if not using Funraise for the primary donation flow.
# NEXT_PUBLIC_GOFUNDME_FUNDRAISER_URL=https://pro.gofundme.com/fundraiser/6498356
# NEXT_PUBLIC_GOFUNDME_CHECKOUT_BASE_URL=https://pro.gofundme.com/give/f6498356/#!/donation/checkout
# NEXT_PUBLIC_GOFUNDME_FUNDRAISER_ID=6498356

# ── Feature flags ─────────────────────────────────────────────────────────
# Set to "false" to hide the interactive map (useful during data-loading).
NEXT_PUBLIC_ENABLE_MAP=true

# ── Strava (optional activity embeds) ────────────────────────────────────
# Comma-separated Strava activity embed URLs
# NEXT_PUBLIC_STRAVA_EMBED_URLS=https://www.strava.com/activities/123456789/embed/abc123
NEXT_PUBLIC_STRAVA_EMBED_URLS=
NEXT_PUBLIC_STRAVA_PROFILE_URL=https://www.strava.com/athletes/your-athlete-id

# ── Funraise scraper (GitHub Actions) ────────────────────────────────────
# Optional bearer token for authenticated Funraise API access during scraping.
# FUNRAISE_AUTH_BEARER=your-bearer-token-here
